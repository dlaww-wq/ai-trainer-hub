generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  businessType String?
  businessName String?
  onboarded    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  learningPacks LearningPack[]
  agentRuns     AgentRun[]
  chatMessages  ChatMessage[]
  storeAgents   StoreAgent[]
  tokenUsages   TokenUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ────────────────────────────────────────────

model Template {
  id            String @id @default(cuid())
  name          String
  industry      String
  purpose       String
  systemPrompt  String
  dataChecklist String @default("[]") // JSON string
  agentConfig   String @default("{}") // JSON string
  level         Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningPacks LearningPack[]
}

model LearningPack {
  id            String @id @default(cuid())
  userId        String
  templateId    String?
  name          String
  status        String @default("draft") // draft | learning | ready | active
  level         Int    @default(1)       // 1-4
  contextData   Int    @default(0)
  visualData    Int    @default(0)
  audioData     Int    @default(0)
  qualityScore  Float  @default(0)
  systemPrompt  String @default("")
  knowledgeBase String @default("{}") // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  agentRuns AgentRun[]
}

model AgentRun {
  id             String @id @default(cuid())
  userId         String
  learningPackId String?
  agentType      String // context_weaver | visual_scout | audio_digester | synthesis | quality_auditor
  status         String @default("pending") // pending | running | completed | failed
  progress       Int    @default(0)         // 0-100
  input          String @default("{}") // JSON string
  output         String @default("{}") // JSON string
  tokensUsed     Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPack LearningPack? @relation(fields: [learningPackId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id       String @id @default(cuid())
  userId   String
  role     String // user | assistant | system
  content  String
  metadata String @default("{}") // JSON string

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RAG / Store Agent ─────────────────────────────────────

// 매장별 AI 에이전트 (네이버 플레이스 slug 기반)
model StoreAgent {
  id           String @id @default(cuid())
  slug         String @unique // URL: /store/[slug]
  userId       String
  businessName String
  businessType String @default("general")
  systemPrompt String @default("")
  status       String @default("draft") // draft | active | paused

  totalChats   Int    @default(0)
  monthlyChats Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]
  convos StoreConversation[]
}

// 학습된 지식 청크 (RAG용)
model KnowledgeChunk {
  id           String @id @default(cuid())
  storeAgentId String
  content      String // 실제 텍스트 내용
  category     String @default("general") // menu | hours | faq | policy | etc
  source       String @default("manual") // manual | file | url
  chunkIndex   Int    @default(0)
  tokenCount   Int    @default(0)

  createdAt DateTime @default(now())

  storeAgent StoreAgent @relation(fields: [storeAgentId], references: [id], onDelete: Cascade)
}

// 고객 대화 기록 (에스컬레이션 포함)
model StoreConversation {
  id           String @id @default(cuid())
  storeAgentId String
  sessionId    String
  messages     String @default("[]") // JSON array
  escalated    Boolean @default(false)
  resolved     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeAgent StoreAgent @relation(fields: [storeAgentId], references: [id], onDelete: Cascade)
}

// 토큰 사용량 추적
model TokenUsage {
  id         String @id @default(cuid())
  userId     String
  feature    String // learn | chat | agent
  model      String @default("claude-sonnet-4-6")
  inputTokens  Int  @default(0)
  outputTokens Int  @default(0)
  cost         Float @default(0) // USD

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
