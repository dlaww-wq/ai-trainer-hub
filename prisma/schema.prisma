generator client {
  provider = "prisma-client-js"
}

datasource db {
  // production: PostgreSQL (Railway) · DATABASE_URL=postgresql://... 환경변수 필수
  // 로컬 SQLite 개발 시에만 일시 변경 — 절대 sqlite로 commit 금지 (OAuth Callback 에러 회귀 발생)
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  businessType String?
  businessName String?
  onboarded    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  learningPacks  LearningPack[]
  agentRuns      AgentRun[]
  chatMessages   ChatMessage[]
  storeAgents    StoreAgent[]
  tokenUsages    TokenUsage[]
  subscription   Subscription?
  tokenCredit    TokenCredit?
  tokenPurchases TokenPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ────────────────────────────────────────────

model Template {
  id            String @id @default(cuid())
  name          String
  industry      String
  purpose       String
  systemPrompt  String
  dataChecklist String @default("[]") // JSON string
  agentConfig   String @default("{}") // JSON string
  level         Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningPacks LearningPack[]
}

model LearningPack {
  id            String @id @default(cuid())
  userId        String
  templateId    String?
  name          String
  status        String @default("draft") // draft | learning | ready | active
  level         Int    @default(1)       // 1-4
  contextData   Int    @default(0)
  visualData    Int    @default(0)
  audioData     Int    @default(0)
  qualityScore  Float  @default(0)
  systemPrompt  String @default("")
  knowledgeBase String @default("{}") // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  agentRuns AgentRun[]
}

model AgentRun {
  id             String @id @default(cuid())
  userId         String
  learningPackId String?
  agentType      String // context_weaver | visual_scout | audio_digester | synthesis | quality_auditor
  status         String @default("pending") // pending | running | completed | failed
  progress       Int    @default(0)         // 0-100
  input          String @default("{}") // JSON string
  output         String @default("{}") // JSON string
  tokensUsed     Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPack LearningPack? @relation(fields: [learningPackId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id       String @id @default(cuid())
  userId   String
  role     String // user | assistant | system
  content  String
  metadata String @default("{}") // JSON string

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RAG / Store Agent ─────────────────────────────────────

// 매장별 AI 에이전트 (네이버 플레이스 slug 기반)
model StoreAgent {
  id           String @id @default(cuid())
  slug         String @unique // URL: /store/[slug]
  userId       String
  businessName String
  businessType String @default("general")
  systemPrompt String @default("")
  status       String @default("draft") // draft | active | paused

  ownerPhone   String @default("") // 카카오 알림 수신 번호
  ownerKakaoId String @default("") // 카카오 채널 수신자 ID

  totalChats   Int    @default(0)
  monthlyChats Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]
  convos StoreConversation[]
  escalations EscalationEvent[]
}

// 학습된 지식 청크 (RAG용)
model KnowledgeChunk {
  id           String @id @default(cuid())
  storeAgentId String
  content      String // 실제 텍스트 내용
  category     String @default("general") // menu | hours | faq | policy | etc
  source       String @default("manual") // manual | file | url
  chunkIndex   Int    @default(0)
  tokenCount   Int    @default(0)

  createdAt DateTime @default(now())

  storeAgent StoreAgent @relation(fields: [storeAgentId], references: [id], onDelete: Cascade)
}

// 고객 대화 기록 (에스컬레이션 포함)
model StoreConversation {
  id           String @id @default(cuid())
  storeAgentId String
  sessionId    String
  messages     String @default("[]") // JSON array
  escalated    Boolean @default(false)
  resolved     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeAgent StoreAgent @relation(fields: [storeAgentId], references: [id], onDelete: Cascade)
}

// 토큰 사용량 추적
model TokenUsage {
  id         String @id @default(cuid())
  userId     String
  feature    String // learn | chat | agent
  model      String @default("claude-sonnet-4-6")
  inputTokens  Int  @default(0)
  outputTokens Int  @default(0)
  cost         Float @default(0) // USD

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── 에스컬레이션 이벤트 ────────────────────────────────────

model EscalationEvent {
  id           String @id @default(cuid())
  storeAgentId String
  sessionId    String
  customerMsg  String // 고객의 마지막 메시지
  aiResponse   String // AI가 에스컬레이션 판단한 응답
  status       String @default("pending") // pending | notified | resolved | ignored
  notifyMethod String @default("none") // none | email | kakao | sms
  resolvedAt   DateTime?
  ownerNote    String @default("")
  ownerAnswer  String @default("") // 사장님이 카톡으로 답변한 내용
  savedToKb    Boolean @default(false) // KB에 저장됐는지

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeAgent StoreAgent @relation(fields: [storeAgentId], references: [id], onDelete: Cascade)
}

// ─── 토큰 크레딧 (API 중매 사용료) ─────────────────────────────

// 사용자 잔액 지갑 (KRW 단위)
model TokenCredit {
  id      String @id @default(cuid())
  userId  String @unique
  balance Float  @default(0) // KRW 잔액

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 크레딧 구매 이력
model TokenPurchase {
  id        String @id @default(cuid())
  userId    String
  packageId String // credit_1k | credit_5k | credit_10k | credit_30k | credit_100k
  amount    Int    // 실제 결제금액 (KRW)
  credit    Float  // 충전된 크레딧 (보너스 포함, KRW)
  bonus     Float  @default(0) // 보너스 크레딧 (KRW)
  status    String @default("pending") // pending | confirmed | failed | refunded

  tossOrderId    String? @unique
  tossPaymentKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── 출장 설치 서비스 예약 ──────────────────────────────────────

model InstallRequest {
  id          String @id @default(cuid())
  userId      String?          // 로그인한 경우
  name        String           // 신청자 이름
  phone       String           // 연락처
  email       String           // 이메일
  businessName String          // 업체명
  businessType String          // 업종
  address     String           // 방문 주소
  region      String           // 지역: seoul | gyeonggi | other
  packageId   String           // basic_install | standard | expert
  preferDate  String           // 희망 방문일
  preferTime  String           // 희망 시간대
  memo        String @default("") // 추가 요청사항
  status      String @default("pending") // pending | confirmed | completed | cancelled
  adminNote   String @default("") // 관리자 메모
  totalAmount Int    @default(0)  // 최종 견적 (KRW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 구독/결제 ──────────────────────────────────────────────

model Subscription {
  id         String @id @default(cuid())
  userId     String @unique
  plan       String @default("free") // free | basic | standard | premium
  status     String @default("active") // active | paused | cancelled
  monthlyChats Int  @default(100) // 플랜별 월 한도
  usedChats    Int  @default(0)
  billingStart DateTime @default(now())
  billingEnd   DateTime?

  tossOrderId    String? @unique
  tossPaymentKey String?
  amount         Int     @default(0) // KRW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User 모델에 Subscription 추가를 위한 relation은 User 모델에서 처리됨
