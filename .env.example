# ============================================================
# 나우링크 — 환경변수 예시
# 사용법: cp .env.example .env.local 후 값 입력
# 자세한 발급 방법: API_CONNECTIONS.md 참고
# ============================================================

# ── 필수: NextAuth ───────────────────────────────────────────
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-random-32-chars
# 로컬: http://localhost:3000 / 배포: https://www.nowlink.kr
NEXTAUTH_URL=http://localhost:3000

# ── OAuth: 카카오 (가장 중요) ─────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── OAuth: 네이버 ────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── OAuth: 구글 ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI: Anthropic Claude ─────────────────────────────────────
# 발급: https://console.anthropic.com
# 없으면 Mock 모드로 동작 (고정 응답만 표시)
ANTHROPIC_API_KEY=
# 모델 변경 시 여기만 수정 (기본값: claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# ── AI: Voyage (한국어 임베딩 — RAG용) ──────────────────────
# 발급: https://dash.voyageai.com
# RAG 검색 시 코사인 유사도 임베딩에 사용
# 없으면 키워드 매칭 폴백으로 자동 전환 (기능 정상 동작)
# 한국어 최적 모델: voyage-multilingual-2
VOYAGE_API_KEY=

# ── 결제: 토스페이먼츠 ──────────────────────────────────────
# 발급: https://developers.tosspayments.com
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Webhook 서명 검증용 시크릿 (토스 대시보드에서 발급)
TOSS_WEBHOOK_SECRET=

# ── 데이터베이스: PostgreSQL ─────────────────────────────────
# Railway PostgreSQL 서비스 추가 시 자동 연결됨
DATABASE_URL=postgresql://user:password@localhost:5432/nowlink

# ── 음성: ElevenLabs (선택) ──────────────────────────────────
ELEVENLABS_API_KEY=

# ── 이미지 저장: Cloudinary (선택) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
